        {
          "binding": "CONTENT",
          "id": "cacb8716fa9745259c9043583fa0727a"
        }
      ],
      "vars": {
        "ALLOWED_ORIGINS": "https://sanity-clone-demo.caelin-deb.workers.dev,https://sanity-clone-studio.caelin-deb.workers.dev",
        "REVALIDATE_WEBHOOKS": "https://sanity-clone-demo.caelin-deb.workers.dev/api/revalidate"
      }
    }
  },
  "observability": { "enabled": true }
}
