{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "sanity-clone-api",
  "main": "src/index.ts",
  "compatibility_date": "2024-12-01",
  "compatibility_flags": ["nodejs_compat"],
  "account_id": "deb0c7508e3246678e8d4c1c33882b20",
  "kv_namespaces": [
    {
