---
export const prerender = false

import Base from "../../../layouts/Base.astro"
import PortableText from "../../../components/PortableText.astro"
import { cms } from "../../../lib/cms"
import { setPreviewNoStore } from "../../../lib/preview"
import { postBySlugQuery } from "../../../lib/queries"
import type { PostBySlugQueryResult } from "../../../generated"

setPreviewNoStore(Astro.response)

const slug = Astro.params.slug ?? ""
const post = await cms.sanityFetch<PostBySlugQueryResult>(
  Astro,
  postBySlugQuery.query,
  { slug },
  { cache: "no-store" },
)
if (!post) Astro.response.status = 404
---
{post ? (
  <Base title={post.title}>
    <article>
      <h1>{post.title}</h1>
      {post.author?.name ? <p class="meta">by {post.author.name}</p> : null}
      <div class="post-body">
        <PortableText blocks={post.body as any} />
      </div>
    </article>
  </Base>
) : (
  <p>Not found</p>
)}
